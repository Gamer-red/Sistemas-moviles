<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- Título del post -->
    <TextView
        android:id="@+id/tvPostTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título del post"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Opciones para publicaciones publicadas -->
    <LinearLayout
        android:id="@+id/layoutOpcionesPublicado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opciones"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditarPost"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="EDITAR PUBLICACIÓN"
            app:icon="@android:drawable/ic_menu_edit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarPost"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="ELIMINAR PUBLICACIÓN"
            app:icon="@android:drawable/ic_menu_delete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#F44336"
            app:iconTint="#F44336"/>
    </LinearLayout>

    <!-- Opciones para borradores -->
    <LinearLayout
        android:id="@+id/layoutOpcionesBorrador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opciones de borrador"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPublicarAhora"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="PUBLICAR AHORA"
            app:icon="@android:drawable/ic_menu_send"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditarBorrador"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="EDITAR BORRADOR"
            app:icon="@android:drawable/ic_menu_edit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarBorrador"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="ELIMINAR BORRADOR"
            app:icon="@android:drawable/ic_menu_delete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#F44336"
            app:iconTint="#F44336"/>
    </LinearLayout>

    <!-- Botón cancelar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="CANCELAR"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_marginTop="16dp"/>

</LinearLayout>